{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SqlConnection": "Host=localhost;Port=5432;Username=hangman;Password=hangman;Database=hangman;"
  },
  "HealthChecksUI": {
    "HealthChecks": [
      {
        "Name": "App Required Services",
        "Uri": "/healthcheck"
      }
    ],
    "EvaluationTimeInSeconds": 10,
    "MinimumSecondsBetweenFailureNotifications": 30
  },
  "Serilog": {
    "Using": [
      "Serilog",
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Elasticsearch",
      "Serilog.Enrichers.CorrelationId",
      "Serilog.Settings.Configuration"
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithCorrelationId",
      "WithCorrelationIdHeader"
    ],
    "Properties": {
      "ApplicationName": "Hangman",
      "Environment": "Local"
    },
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "EndsWith(RequestPath, '/healthcheck')"
        }
      },
      {
        "Name": "ByExcluding",
        "Args": {
          "expression": "Scope[?] = 'HealthReportCollector is collecting health checks results.'"
        }
      }
    ],
    "WriteTo": [
      {
        "Name": "Async",
        "Args": {
          "configure": [
            {
              "Name": "Console"
            }
          ]
        }
      }
    ]
  }
}