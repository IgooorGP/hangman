### gets room by id
GET http://localhost:8080/api/v1/gameroom/123
Content-Type: application/json

### gets all rooms (default pagination)
GET http://localhost:8080/api/v1/gameroom/
Content-Type: application/json

### gets all rooms (paginated)
GET http://localhost:8080/api/v1/gameroom/
    ?offset=2
    &limit=4
Content-Type: application/json

### gets gamerooms by name (paginated)
GET http://localhost:8080/api/v1/gameroom/
    ?offset=0
    &limit=10
    &name=igu room
Content-Type: application/json

### creates a new gameroom
POST http://localhost:8080/api/v1/gameroom/
Content-Type: application/json

{
    "name": "igu room",
    "description": "a nice room",
    "max_concurrent_users": 2
}